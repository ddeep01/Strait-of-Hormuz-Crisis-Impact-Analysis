    <worksheet name='Sheet 3'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#336699'>Geopolitical Risk Exposure of India&apos;s Fertilizer Suppliers (FY 2025–26)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='India_Fertilizer_Country_Share_Urea_DAP_2022_2026' name='federated.1ggszhe0jf6lhg1d4fwbl0ltslgg' />
          </datasources>
          <datasource-dependencies datasource='federated.1ggszhe0jf6lhg1d4fwbl0ltslgg'>
            <column caption='Risk level' datatype='string' name='[Calculation_1271333128290309]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Country] = &quot;Saudi Arabia&quot;&#13;&#10;OR [Country] = &quot;Oman&quot;&#13;&#10;OR [Country] = &quot;Qatar&quot;&#13;&#10;OR [Country] = &quot;UAE&quot;&#13;&#10;OR [Country] = &quot;Bahrain&quot;&#13;&#10;OR [Country] = &quot;Kuwait&quot;&#13;&#10;OR [Country] = &quot;Iran&quot;&#13;&#10;THEN &quot;High&quot;&#13;&#10;&#13;&#10;ELSEIF [Country] = &quot;Jordan&quot;&#13;&#10;OR [Country] = &quot;Egypt&quot;&#13;&#10;THEN &quot;Medium&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;Low&quot;&#13;&#10;END' />
            </column>
