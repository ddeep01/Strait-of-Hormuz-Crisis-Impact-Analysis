      <column caption='Country Share' datatype='string' name='[Calculation_1271333119709184]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country_Share_Percent] &lt; 5 THEN&#13;&#10;    &quot;Others&quot;&#13;&#10;ELSE&#13;&#10;    [Country]&#13;&#10;END' />
      </column>
      <column caption='Dummy' datatype='integer' name='[Calculation_1271333120765953]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Country_share' datatype='string' name='[Calculation_1271333124509698]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country_Share_Percent] &lt; 2 THEN&#13;&#10;&quot;Others&quot;&#13;&#10;ELSE&#13;&#10;[Country]&#13;&#10;END' />
      </column>
      <column caption='Country Share %' datatype='real' default-format='p0.00%' name='[Calculation_1271333126443011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Import_LMT]) / SUM([Grand_Total_LMT])' />
      </column>
      <column caption='Risk level' datatype='string' name='[Calculation_1271333128290309]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] = &quot;Saudi Arabia&quot;&#13;&#10;OR [Country] = &quot;Oman&quot;&#13;&#10;OR [Country] = &quot;Qatar&quot;&#13;&#10;OR [Country] = &quot;UAE&quot;&#13;&#10;OR [Country] = &quot;Bahrain&quot;&#13;&#10;OR [Country] = &quot;Kuwait&quot;&#13;&#10;OR [Country] = &quot;Iran&quot;&#13;&#10;THEN &quot;High&quot;&#13;&#10;&#13;&#10;ELSEIF [Country] = &quot;Jordan&quot;&#13;&#10;OR [Country] = &quot;Egypt&quot;&#13;&#10;THEN &quot;Medium&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;Low&quot;&#13;&#10;END' />
